{
  "tool_id": "search_api",
  "category": "information_retrieval",
  "subcategory": "web_search",
  "core_description": "Search for relevant information given a query. Supports keyword and semantic search with configurable result count.",
  "business_scenario": "When the user needs to find factual information, verify claims, or gather evidence from external knowledge sources.",
  "version": "1.0.0",
  "parameters": {
    "type": "object",
    "properties": {
      "query": {
        "type": "String",
        "description": "Search query",
        "required": true
      },
      "top_k": {
        "type": "Integer",
        "description": "Number of results to return",
        "default": 5,
        "required": false
      }
    }
  },
  "return_schema": {
    "results": {
      "type": "array",
      "description": "List of search result strings"
    },
    "total": {
      "type": "Integer",
      "description": "Total number of results found"
    }
  },
  "mock_responses": [
    {
      "condition": "default",
      "response": {
        "results": ["result1", "result2"],
        "total": 2
      }
    }
  ]
}
